                                rootPart.CFrame = antiVoidTargetCFrame
                            end
                        end
                    end)
                    
                    antiVoidPlatform.Parent = Workspace
                end
            else
                if mapPlatform then mapPlatform:Destroy() mapPlatform = nil end
                if antiVoidPlatform then antiVoidPlatform:Destroy() antiVoidPlatform = nil end
            end
            
