local function getTargetCFrame(amountStr)
    for _, buttonModel in pairs(giveWinsFolder:GetChildren()) do
        local winLabel = buttonModel:FindFirstChild("WinAmount", true)
        if winLabel and winLabel:IsA("TextLabel") then
            local numStr = string.match(winLabel.Text, "%d+")
            if numStr == amountStr then
                local touchPart = buttonModel:FindFirstChild("Touch") or buttonModel:FindFirstChildWhichIsA("BasePart", true)
                if touchPart then
                    return touchPart.CFrame
                end
            end
        end
    end
    return farmCFrames[amountStr]
end

local function smoothMoveTo(targetCFrame, speed, conditionCheck)
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if not rootPart or not humanoid then return end

    isMoving = true
    humanoid.PlatformStand = true

    local noclipConnection
    noclipConnection = RunService.Stepped:Connect(function()
        if player.Character then
            for _, part in pairs(player.Character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)

    while rootPart and rootPart.Parent and (conditionCheck == nil or conditionCheck()) do
        local currentPos = rootPart.Position
        local targetPos = targetCFrame.Position
        local distance = (targetPos - currentPos).Magnitude

        if distance < 1.5 then
            rootPart.CFrame = targetCFrame
            break
        end

        local direction = (targetPos - currentPos).Unit
        local dt = RunService.Heartbeat:Wait()
        local moveStep = direction * math.min(speed * dt, distance)
        
        rootPart.CFrame = CFrame.new(currentPos + moveStep, targetPos)
    end

    if player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
        player.Character:FindFirstChildOfClass("Humanoid").PlatformStand = false
    end
    if noclipConnection then noclipConnection:Disconnect() end
    isMoving = false
end

