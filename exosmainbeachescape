local function createTab(name, order)
    local btn = Instance.new("TextButton", tabContainer)
    btn.Size = UDim2.new(0.92, 0, 0, 28)
    btn.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
    btn.Text = "  " .. name
    btn.TextColor3 = Color3.fromRGB(160, 160, 165)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.BorderSizePixel = 0
    btn.LayoutOrder = order
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
    
    local page = Instance.new("Frame", rightPanel)
    page.Size = UDim2.new(1, 0, 1, 0)
    page.Position = UDim2.new(0, 30, 0, 0)
    page.BackgroundTransparency = 1
    page.Visible = false
    
    pages[name] = page
    tabButtons[name] = btn
end

createTab("Fly", 1)
createTab("Settings", 2)

local currentTab = ""
local function switchTab(tabName)
    if currentTab == tabName then return end
    currentTab = tabName
    for name, page in pairs(pages) do
        local btn = tabButtons[name]
        if name == tabName then
            page.Visible = true
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            btn.BackgroundColor3 = Color3.fromRGB(28, 28, 32)
        else
            page.Visible = false
            btn.TextColor3 = Color3.fromRGB(160, 160, 165)
            btn.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
        end
    end
end

switchTab("Fly")
tabButtons["Fly"].MouseButton1Click:Connect(function() switchTab("Fly") end)
tabButtons["Settings"].MouseButton1Click:Connect(function() switchTab("Settings") end)

